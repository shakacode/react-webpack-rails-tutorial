#!/usr/bin/env bash
# Generated by shakacode/agent-workflows agent-workflow-seam-doctor --init.
set -euo pipefail
cd "$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"

renderer_started=false
renderer_pid=''

cleanup_renderer() {
  local status=$?

  if [[ "$renderer_started" == true ]] && kill -0 "$renderer_pid" 2>/dev/null; then
    kill "$renderer_pid" 2>/dev/null || true
    wait "$renderer_pid" 2>/dev/null || true
  fi

  exit "$status"
}

trap cleanup_renderer EXIT

if nc -z localhost 3800 2>/dev/null; then
  echo "Reusing existing Node renderer on port 3800."
else
  bin/conductor-exec node renderer/node-renderer.js &
  renderer_pid=$!
  renderer_started=true

  echo "Waiting for Node renderer (PID $renderer_pid) on port 3800..."
  for _ in $(seq 1 30); do
    if ! kill -0 "$renderer_pid" 2>/dev/null; then
      echo "Node renderer exited unexpectedly (see output above)." >&2
      exit 1
    fi
    if nc -z localhost 3800 2>/dev/null; then
      break
    fi
    sleep 1
  done

  if ! nc -z localhost 3800 2>/dev/null; then
    echo "Node renderer failed to start within 30 seconds (see output above)." >&2
    exit 1
  fi
fi

bin/conductor-exec bin/ci
